{% extends "@Contao/content_element/swiper.html.twig" %}

{#
Adjust how any blocks of parent or used component templates are rendered.
Try typing "block" or "use" to get autocompletion for available options.
#}


{% set slider_settings = slider_settings|merge({
    pagination: data.swiperSliderPagination ? {
        el: '.swiper-pagination',
        clickable: true
    } : false,
    navigation: data.swiperSliderNavigation ? {
        prevEl: '.swiper-button-prev',
        nextEl: '.swiper-button-next'
    } : false
}) %}

{% if data.swiperSliderCustomOptions %}
    {% set slider_settings = slider_settings|merge(data.swiperSliderCustomOptions|deserialize) %}
{% endif %}


{% block init_options %}
    {# Put custom options here #}
{% endblock %}
