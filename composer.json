{
  "name": "plakart/contao-swiper-extension",
  "type": "contao-bundle",
  "description": "Erweitert den Standard-Contao Swiper um weitere Optionen",
  "license": "LGPL-3.0-or-later",
  "authors": [
    {
      "name": "Agentur plakart",
      "email": "technik@plakart.de",
      "homepage": "https://plakart.de",
      "role": "Publisher"
    },
    {
      "name": "Jannik Nölke",
      "email": "jannik.noelke@plakart.de",
      "homepage": "https://plakart.de",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.3",
    "contao/core-bundle": ">=5.6"
  },
  "conflict": {
    "contao/manager-plugin": "<2.0 || >=3.0"
  },
  "require-dev": {
    "contao/manager-plugin": "^2.0"
  },
  "extra": {
    "contao-manager-plugin": "Plakart\\ContaoSwiperExtensionBundle\\ContaoManager\\Plugin"
  },
  "autoload": {
    "psr-4": {
      "Plakart\\ContaoSwiperExtensionBundle\\": "src/"
    }
  }
}